{
  "name": "mongoose-construct-hook",
  "version": "1.0.0",
  "description": "Mongoose plugin: pre/post construct hooks that fire when documents are instantiated (new Model() or hydrated from DB)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/post-build.mjs",
    "build:watch": "tsup --watch --onSuccess \"node scripts/post-build.mjs\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mongoose",
    "plugin",
    "hooks",
    "construct",
    "init"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "peerDependencies": {
    "mongoose": "^7.0.0 || ^8.0.0 || ^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "mongoose": "^9.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4",
    "vitest": "^2.1.6"
  }
}
